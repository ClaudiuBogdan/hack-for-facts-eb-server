{
  "name": "transparenta-eu-server",
  "version": "0.1.0",
  "description": "Transparenta.eu server used to analyze and visualize public budget data from Romania",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a",
  "scripts": {
    "check:staged-secrets": "node scripts/check-staged-secrets.mjs",
    "dev": "tsx watch --clear-screen=false --env-file=.env src/api.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/api.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write '**/*.{ts,json,md}'",
    "format:check": "prettier --check '**/*.{ts,json,md}'",
    "openapi:yaml": "tsx scripts/generate-openapi.ts",
    "test": "vitest run --exclude 'tests/e2e/**' --exclude 'tests/golden-master/**'",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:gm": "export TEST_GM_API_URL=http://localhost:3001/graphql && vitest run tests/golden-master --config vitest.gm.config.ts",
    "test:gm:update": "export TEST_GM_API_URL=http://localhost:3001/graphql && vitest run tests/golden-master --config vitest.gm.config.ts --update",
    "test:watch": "vitest --exclude 'tests/e2e/**'",
    "test:coverage": "vitest run --coverage --exclude 'tests/e2e/**'",
    "validate-datasets": "tsx scripts/validate-datasets.ts",
    "pdf:extract-tables": "python3 scripts/extract_pdf_tables.py",
    "pdf:extract-batch-anexa3": "python3 scripts/extract_pdf_tables_batch.py",
    "pdf:extract-alte-bugete": "python3 scripts/alte-bugete/extract_budget_items.py",
    "pdf:merge-budget-summary": "python3 scripts/merge_budget_indicator_summaries.py",
    "pdf:validate-consistency": "python3 scripts/validate_budget_indicator_consistency.py",
    "pdf:validate-totals": "python3 scripts/validate_pdf_totals.py",
    "pdf:tables-to-xlsx": "python3 scripts/csvs_to_xlsx.py",
    "ins:audit": "tsx scripts/audit-ins-availability.ts",
    "jwt-security-test": "tsx security-tests/jwt-security/cli.ts",
    "jwt-inspect": "tsx security-tests/jwt-security/inspect.ts",
    "email:dev": "email dev --dir src/modules/email-templates/shell/templates",
    "deps:check": "madge --circular --extensions ts src/",
    "deps:summary": "madge --extensions ts --json src/ | node -e \"const d=JSON.parse(require('fs').readFileSync(0,'utf8'));console.log('Files:',Object.keys(d).length);console.log('Imports:',Object.values(d).flat().length)\"",
    "deps:graph": "echo 'Requires Graphviz: brew install graphviz (macOS) or apt install graphviz (Linux)' && madge --image deps-graph.svg --extensions ts src/",
    "ci": "pnpm typecheck && pnpm lint && pnpm deps:check && pnpm test && pnpm run deps:check && pnpm build",
    "prepare": "husky",
    "clean": "rm -rf dist coverage deps-graph.svg"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/swagger": "^9.7.0",
    "@graphql-tools/schema": "^10.0.31",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-logs": "^0.213.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "@sinclair/typebox": "^0.34.48",
    "bullmq": "^5.71.1",
    "decimal.js": "^10.6.0",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "fuse.js": "^7.1.0",
    "graphql": "^16.13.2",
    "graphql-depth-limit": "^1.1.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "kysely": "^0.28.14",
    "mercurius": "^16.8.0",
    "neverthrow": "^8.2.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "resend": "^6.9.4",
    "svix": "^1.89.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^10.0.1",
    "@react-email/preview-server": "5.2.10",
    "@testcontainers/postgresql": "^11.13.0",
    "@types/graphql-depth-limit": "^1.1.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.1",
    "baseline-browser-mapping": "^2.10.10",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "kysely-codegen": "^0.20.0",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-email": "^5.2.10",
    "testcontainers": "^11.13.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
